# ============================================================
# SkyTrust 环境变量模板
# 复制为 .env 后填入真实密钥: cp .env.example .env
# .env 已被 .gitignore 排除，不会被提交到 Git
# ============================================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_DATABASE=skytrust_dev
MYSQL_USER=skytrust
MYSQL_PASSWORD=change_this_password

# ---- Redis ----
REDIS_PASSWORD=

# ---- RabbitMQ ----
RABBITMQ_DEFAULT_USER=skytrust
RABBITMQ_DEFAULT_PASS=change_this_password

# ---- MinIO ----
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change_this_minio_password

# ---- MQTT (Mosquitto) ----
MQTT_USERNAME=skytrust
MQTT_PASSWORD=change_this_mqtt_password

# ---- JWT ----
JWT_SECRET=generate-a-256-bit-random-secret-here

# ---- Ganache (开发环境) ----
GANACHE_MNEMONIC="myth like bonus scare over problem client lizard pioneer submit female collect"

# ---- 应用 (skytrust-app) ----
DB_HOST=mysql
DB_PORT=3306
DB_NAME=skytrust_dev
DB_USER=skytrust
DB_PASSWORD=change_this_password

REDIS_HOST=redis
REDIS_PORT=6379

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=skytrust
RABBITMQ_PASSWORD=change_this_password

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=change_this_minio_password

MQTT_BROKER_URL=tcp://mqtt:1883

BLOCKCHAIN_NODE_URL=http://ganache:8545
BLOCKCHAIN_CHAIN_ID=1337

AI_SERVICE_URL=http://ai-service:5000
